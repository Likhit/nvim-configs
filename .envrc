use flake

export NVIM_APPNAME="nvim-dev"
ln -sfn "$(pwd)" "$HOME/.config/nvim-dev"

# Symlink plugins from the cached devShell into the Neovim pack path
if [ -n "$NVIM_PLUGINS" ]; then
  mkdir -p "$HOME/.local/share/nvim-dev/site/pack"
  ln -sfn "$NVIM_PLUGINS" "$HOME/.local/share/nvim-dev/site/pack/nix"
fi
