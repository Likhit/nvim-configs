if command -v nix &> /dev/null; then
  use flake
fi

export NVIM_APPNAME="nvim-dev"
ln -sfn "$(pwd)" "$HOME/.config/nvim-dev"

# Build and symlink plugins from nixpkgs into the Neovim pack path
if command -v nix &> /dev/null; then
  plugin_dir=$(nix build .#nvim-plugins --no-link --print-out-paths 2>/dev/null)
  if [ -n "$plugin_dir" ]; then
    mkdir -p "$HOME/.local/share/nvim-dev/site/pack"
    ln -sfn "$plugin_dir" "$HOME/.local/share/nvim-dev/site/pack/nix"
  fi
fi
